{
  "name": "goland-exact-theme",
  "displayName": "GoLand Exact Theme",
  "description": "A custom dark theme tuned to closely match the GoLand dark UI and Go syntax colors.",
  "version": "1.0.0",
  "publisher": "sagaryadaviitk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sagaryadaviitk/goland-exact-theme.git"
  },
  "homepage": "https://github.com/sagaryadaviitk/goland-exact-theme",
  "bugs": {
    "url": "https://github.com/sagaryadaviitk/goland-exact-theme/issues"
  },
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onCommand:golandExactTheme.revealActiveFile",
    "onLanguage:go",
    "onStartupFinished"
  ],
  "keywords": [
    "theme",
    "goland",
    "jetbrains",
    "go",
    "dark"
  ],
  "files": [
    "extension.js",
    "icons/**",
    "themes/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "contributes": {
    "themes": [
      {
        "label": "GoLand Exact Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/goland-exact-dark-color-theme.json"
      }
    ],
    "iconThemes": [
      {
        "id": "goland-exact-icons",
        "label": "GoLand Exact Icons",
        "path": "./icons/goland-exact-icons.json"
      }
    ],
    "commands": [
      {
        "command": "golandExactTheme.revealActiveFile",
        "title": "Reveal Active File",
        "icon": "$(target)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "golandExactTheme.revealActiveFile",
          "when": "view == workbench.explorer.fileView",
          "group": "navigation@18"
        }
      ]
    }
  },
  "scripts": {
    "validate": "node -c extension.js && node -e \"JSON.parse(require('fs').readFileSync('package.json','utf8')); JSON.parse(require('fs').readFileSync('icons/goland-exact-icons.json','utf8')); JSON.parse(require('fs').readFileSync('themes/goland-exact-dark-color-theme.json','utf8')); console.log('ok')\""
  }
}
